# ── Magento GraphQL connector (server-only) ────────────────────────────────
# These two vars ALONE repoint the adapter at any Magento instance — no code
# change. NEVER prefix any Magento value with NEXT_PUBLIC_ — this preserves the
# server-only trust boundary: the connector is server-only and the browser must
# never see the endpoint.
# Currency is NOT configured here — it is resolved from the Magento store SCOPE
# (Store View → Website → Default) via storeConfig, like categories/nav/CMS.
MAGENTO_GRAPHQL_ENDPOINT=https://249.magento.default/graphql
MAGENTO_STORE_CODE=default

# TLS trust for the mkcert-signed dev backend. Required by `pnpm schema:pull`
# (and any server-side fetch) to trust https://249.magento.default locally.
NODE_EXTRA_CA_CERTS=/home/dasun/.local/share/mkcert/rootCA.pem

# ── Home merchandising slot → curation-category id (optional overrides) ─────
# Defaults (below) match the Luma-seeded curation categories in the dev backend.
# Uncomment to repoint a slot at a different category on another instance.
# MAGENTO_CAT_HIGHLIGHTED=41
# MAGENTO_CAT_WEEKDEALS=42
# MAGENTO_CAT_NEW_IN=43
# MAGENTO_CAT_FEATURED=44
# MAGENTO_CAT_PRODUCT_OF_MONTH=45
