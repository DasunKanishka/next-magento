{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "schema:pull": "node scripts/schema-pull.mjs",
    "codegen": "graphql-codegen --config codegen.ts",
    "codegen:check": "node scripts/codegen-check.mjs",
    "check:imports": "bash scripts/check-adapter-imports.sh",
    "check:no-public-secrets": "bash scripts/check-no-public-secrets.sh",
    "check:contract-neutral": "bash scripts/check-contract-neutral.sh"
  },
  "dependencies": {
    "@graphql-typed-document-node/core": "^3.2.0",
    "graphql": "^17.0.2",
    "graphql-request": "^7.4.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^7.2.0",
    "@graphql-codegen/client-preset": "^6.1.0",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "eslint-config-prettier": "^10.1.8",
    "get-graphql-schema": "^2.1.2",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.4",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
