{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NODE_OPTIONS=--use-system-ca next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "perf:gate": "node scripts/perf-gate.mjs",
    "schema:pull": "node scripts/schema-pull.mjs",
    "codegen": "graphql-codegen --config codegen.ts",
    "codegen:check": "node scripts/codegen-check.mjs",
    "check:imports": "bash scripts/check-adapter-imports.sh",
    "check:no-public-secrets": "bash scripts/check-no-public-secrets.sh",
    "check:contract-neutral": "bash scripts/check-contract-neutral.sh",
    "check:no-internal-vocab": "bash scripts/check-no-internal-vocab.sh",
    "check:no-hardcoded-style-literals": "bash scripts/check-no-hardcoded-style-literals.sh",
    "check:no-hardcoded-content": "bash scripts/check-no-hardcoded-content.sh",
    "check:framework-currency": "bash scripts/check-framework-currency.sh",
    "check:no-ai-artifacts": "bash scripts/check-no-ai-artifacts.sh",
    "prepare": "git config core.hooksPath .githooks || true"
  },
  "dependencies": {
    "@graphql-typed-document-node/core": "^3.2.0",
    "graphql": "^17.0.2",
    "graphql-request": "^7.4.0",
    "isomorphic-dompurify": "^3.18.0",
    "next": "16.2.10",
    "next-intl": "^4.13.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@graphql-codegen/cli": "^7.2.0",
    "@graphql-codegen/client-preset": "^6.1.0",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "axe-core": "^4.12.1",
    "chrome-launcher": "^1.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-i18next": "^6.1.5",
    "get-graphql-schema": "^2.1.2",
    "jsdom": "^29.1.1",
    "lighthouse": "13.4.0",
    "prettier": "^3.9.4",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
